# ============================================================================
#  Hermes orchestration — environment template
# ============================================================================
#  HOW TO USE:
#    1. Copy this file to ".env"  ->  cp .env.template .env
#    2. Paste your real keys after each "=" in .env  (NOT in this template).
#    3. .env is gitignored — it never gets committed or pushed. Verify with:
#         git check-ignore .env        (should print: .env)
#    4. Full step-by-step on where to get each key: SECRETS_SETUP.md
#
#  RULE: real key values live ONLY in your local .env (and AWS Secrets Manager
#  for production). They must NEVER appear in this template or anywhere in git.
# ============================================================================

# --- Direct provider keys (LiteLLM uses these first) ---
ANTHROPIC_API_KEY=        # Claude Opus / Sonnet / Haiku   -> console.anthropic.com
DEEPSEEK_API_KEY=         # DeepSeek V3 / V4 Flash / V4 Pro -> platform.deepseek.com
ZAI_API_KEY=              # GLM-5.2 (planner)               -> z.ai / open.bigmodel.cn
OPENAI_API_KEY=           # GPT-5.4                         -> platform.openai.com
GOOGLE_API_KEY=           # Gemini 3 Flash / Flash-Lite     -> aistudio.google.com

# --- Failover + testing key (catch-all under everything) ---
OPENROUTER_API_KEY=       # any model not covered above     -> openrouter.ai/keys

# --- LiteLLM proxy ---
LITELLM_MASTER_KEY=       # a password you invent; Hermes uses it to call the proxy
LITELLM_PROXY_URL=http://127.0.0.1:4000   # where the proxy listens (change if remote)

# --- Optional: which profile Hermes runs (default | orchestration) ---
HERMES_ACTIVE_PROFILE=orchestration
